# =============================================================================
# .gitignore for Health Dashboard (my-devops-project)
# Python, Docker, Terraform, IDE, OS files
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
venv/
env/
.venv/
*.whl
.pytest_cache/
htmlcov/
.coverage
.tox/

# --- Environment ---
.env
.env.local
!.env.example

# --- Docker ---
*.log
docker-compose.override.yml
security_report_python.json
pip_audit_report.json

# --- Terraform ---
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl
crash.log

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS ---
*.bak
*.tmp

# SSH / TLS keys and cert bundles
my-devops-key.pem
*.pem
*.key
*_rsa
*_rsa.pub
*.p12
*.pfx
server_ip.txt
