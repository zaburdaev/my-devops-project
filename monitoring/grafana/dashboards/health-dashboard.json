{
  "id": null,
  "uid": "health-dashboard-simple",
  "title": "Health Dashboard - Simple",
  "tags": ["health-dashboard", "simple"],
  "timezone": "browser",
  "schemaVersion": 27,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "App Status (up)",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"flask-app\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU Usage %",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "system_cpu_usage_percent",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory Usage %",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "system_memory_usage_percent",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "graph",
      "title": "CPU Trend",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "system_cpu_usage_percent",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "lines": true,
      "linewidth": 2,
      "fill": 1
    },
    {
      "id": 5,
      "type": "graph",
      "title": "Memory Trend",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "system_memory_usage_percent",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "lines": true,
      "linewidth": 2,
      "fill": 1
    }
  ]
}
