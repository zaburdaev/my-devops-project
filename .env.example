# Database Configuration
POSTGRES_USER=healthuser
POSTGRES_PASSWORD=healthpass
POSTGRES_DB=healthdb
DATABASE_URL=postgresql://healthuser:healthpass@postgres:5432/healthdb

# Redis Configuration  
REDIS_URL=redis://redis:6379/0

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Prometheus Configuration
PROMETHEUS_RETENTION_TIME=15d

# Application Configuration
APP_NAME="Health Dashboard"
APP_VERSION=1.0.0
LOG_LEVEL=INFO
